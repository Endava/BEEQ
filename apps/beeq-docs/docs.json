{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "BEEQ Design System",
  "description": "BEEQ is a white-label open-source design system created at Endava that accelerates the building of digital products with the goal of providing a UI Library of components and guidelines to help designers and developers produce high-quality solutions.",
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/beeq-light.svg",
    "dark": "/logo/beeq-dark.svg"
  },
  "icons": {
    "library": "fontawesome"
  },
  "background": {
    "color": {
      "dark": "#0d0e11",
      "light": "#ffffff"
    }
  },
  "colors": {
    "primary": "#4f46e5",
    "light": "#4f46e5",
    "dark": "#4f46e5"
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "dark": "night-owl",
        "light": "one-light"
      }
    }
  },
  "banner": {
    "content": "🚀 Version 2.0 is now live! See our [changelog](/changelog) for details.",
    "dismissible": true
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "getting-started/introduction",
              "getting-started/for-designers",
              "getting-started/for-developers",
              "getting-started/installation"
            ]
          },
          {
            "group": "Framework guides",
            "pages": [
              "guides/frameworks/angular",
              "guides/frameworks/react",
              "guides/frameworks/next.js",
              "guides/frameworks/vue",
              "guides/frameworks/html-web-components"
            ]
          },
          {
            "group": "Foundations",
            "pages": [
              "foundations/overview",
              "foundations/colors",
              "foundations/typography",
              "foundations/spacing",
              "foundations/grid",
              "foundations/icons"
            ]
          },
          {
            "group": "Theming & customization",
            "pages": [
              "theming/overview",
              "theming/global-css-variables",
              "theming/styles",
              "theming/custom-theme"
            ]
          }
        ]
      },
      {
        "tab": "Components",
        "groups": [
          {
            "group": "Actions",
            "pages": [
              "components/button",
              "components/dropdown"
            ]
          },
          {
            "group": "Inputs",
            "pages": [
              "components/input",
              "components/select",
              "components/textarea",
              "components/checkbox",
              "components/radio-button",
              "components/switch"
            ]
          },
          {
            "group": "Feedback",
            "pages": [
              "components/alert",
              "components/toast",
              "components/notification",
              "components/spinner",
              "components/progress"
            ]
          },
          {
            "group": "Navigation",
            "pages": [
              "components/breadcrumb",
              "components/tabs",
              "components/dropdown",
              "components/side-menu",
              "components/stepper"
            ]
          }
        ]
      },
      {
        "tab": "Releases",
        "pages": [
          "releases/changelog",
          "releases/migrations",
          "releases/deprecations"
        ]
      },
      {
        "tab": "About",
        "pages": [
          "about/overview",
          "about/contributing",
          "about/team"
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "navbar": {
    "links": [
      {
        "icon": "code",
        "label": "Storybook",
        "href": "https://storybook.beeq.design"
      },
      {
        "icon": "github",
        "label": "GitHub",
        "href": "https://github.com/Endava/BEEQ"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "chatgpt",
      "claude",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Endava/BEEQ",
      "linkedin": "https://www.linkedin.com/company/endava/",
      "website": "https://www.endava.com"
    }
  }
}
